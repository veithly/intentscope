{
  "name": "intentscope",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "next lint",
    "test:e2e": "playwright test",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "audit:prd": "node ../hackathonhunter/scripts/audit_project.mjs . --phase prd",
    "audit:ui": "node ../hackathonhunter/scripts/audit_project.mjs . --phase ui-libs",
    "audit:density": "node ../hackathonhunter/scripts/audit_project.mjs . --phase feature-density",
    "audit:realness": "node ../hackathonhunter/scripts/audit_project.mjs . --phase realness"
  },
  "dependencies": {
    "@tailwindcss/postcss": "latest",
    "class-variance-authority": "latest",
    "clsx": "latest",
    "lucide-react": "latest",
    "next": "latest",
    "react": "latest",
    "react-dom": "latest",
    "recharts": "latest",
    "tailwind-merge": "latest",
    "tailwindcss": "latest"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "@playwright/test": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "typescript": "latest",
    "wrangler": "^4.94.0"
  }
}
